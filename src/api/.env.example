# Copy to `.env` and adjust. Real environment variables take precedence over
# anything set here. All values below are the built-in defaults.

# --- Database ---
# PostgreSQL connection string (must point at a database with the ttx schema;
# migrations under ../ttx/migrations run automatically on startup).
DATABASE_URL=postgres://postgres:postgres@localhost/ttx

# --- HTTP server ---
# Address the API binds to.
BIND_ADDR=0.0.0.0:3000
# Deployment environment. When set to "production", a missing JWT_KEY aborts
# startup instead of falling back to the insecure development default.
APP_ENV=development

# --- Logging ---
# tracing-subscriber EnvFilter directive (e.g. info, debug, api=debug,tower_http=debug).
RUST_LOG=info

# --- Tracing / OpenTelemetry ---
# Console logging is always on. When OTEL_EXPORTER_OTLP_ENDPOINT is set, spans
# are also exported over OTLP/HTTP to that collector (service name: ttx-api);
# leave it unset to run with console logging only. The standard
# OTEL_EXPORTER_OTLP_* variables (endpoint, headers, timeout) are honoured.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# --- JWT / sessions ---
# Secret used to sign and verify session tokens. REQUIRED in production
# (APP_ENV=production); outside production an unset key falls back to an
# insecure default with a warning. Always set a strong value before deploying.
JWT_KEY=dev-secret-change-me
# Token issuer / audience claims (validated on every request).
JWT_ISSUER=api.ttx.gg
JWT_AUDIENCE=ttx.gg
# Token lifetime in days.
JWT_EXPIRES_DAYS=7

# --- Cache ---
# Optional shared L2 cache (history series + creator-value average). When set,
# the API uses Redis so multiple instances share one warm cache; unset falls
# back to an in-process cache. Should match the jobs runner's REDIS_URL.
# REDIS_URL=redis://localhost:6379

# --- Twitch ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/sessions/twitch/callback
