# Copy to `.env` and adjust. Real environment variables take precedence.

# PostgreSQL connection string. Must point at the same database as the API so
# that NOTIFY-dispatched events reach the API's websocket clients.
DATABASE_URL=postgres://postgres:postgres@localhost/ttx

# tracing-subscriber EnvFilter directive (e.g. info, debug, jobs=debug).
RUST_LOG=info

# --- Optional jobs ---
# Each job below starts only when its config is present.

# StreamMonitorJob (Twitch Helix stream polling). Requires app credentials.
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_REDIRECT_URI=http://localhost:3000/sessions/twitch/callback

# CreatorValueMonitorJob (Redis-backed creator stats + anonymous Twitch chat).
# Set REDIS_URL to enable; chat is read anonymously (no Twitch credentials).
# REDIS_URL=redis://localhost:6379
# Seconds between value digests (default 15).
# CREATOR_VALUES_DELAY_SECS=15
