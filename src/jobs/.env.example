# Copy to `.env` and adjust. Real environment variables take precedence.

# PostgreSQL connection string. Must point at the same database as the API so
# that NOTIFY-dispatched events reach the API's websocket clients.
DATABASE_URL=postgres://postgres:postgres@localhost/ttx

# tracing-subscriber EnvFilter directive (e.g. info, debug, jobs=debug).
RUST_LOG=info

# --- Tracing / OpenTelemetry ---
# Console logging is always on. When OTEL_EXPORTER_OTLP_ENDPOINT is set, spans
# are also exported over OTLP/HTTP to that collector (service name: ttx-jobs);
# leave it unset to run with console logging only. The standard
# OTEL_EXPORTER_OTLP_* variables (endpoint, headers, timeout) are honoured.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# --- Optional jobs ---
# Each job below starts only when its config is present.

# StreamMonitorJob (Twitch Helix stream polling). Requires app credentials.
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_REDIRECT_URI=http://localhost:3000/sessions/twitch/callback

# CreatorValueMonitorJob (Redis-backed creator stats + anonymous Twitch chat).
# Set REDIS_URL to enable; chat is read anonymously (no Twitch credentials).
# REDIS_URL=redis://localhost:6379
# Seconds between value digests (default 15).
# CREATOR_VALUES_DELAY_SECS=15
#
# Chat sharding (Twitch IRC limits channels joined per public IP). When
# CHAT_SHARD_INDEX is set, creators (ordered by id) are split into fixed-size
# chunks and this instance only monitors the chunk at that index, so the job can
# be deployed across multiple machines/IPs. Omit to monitor every creator.
# CHAT_SHARD_INDEX is 0-based; CHAT_SHARD_SIZE defaults to 50.
# CHAT_SHARD_INDEX=0
# CHAT_SHARD_SIZE=50
